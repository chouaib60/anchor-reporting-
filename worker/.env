LOG_LEVEL=INFO
DATABASE_URL=postgresql+asyncpg://raas:raas@postgres:5432/raas
DATABASE_URL_RAW=postgresql://raas:raas@postgres:5432/raas
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false
MINIO_BUCKET_TEMPLATES=templates
MINIO_BUCKET_OUTPUTS=outputs
WORKER_MAX_CONCURRENT_JOBS=4
WORKER_POLL_INTERVAL_SECONDS=5
WORKER_JOB_TIMEOUT_SECONDS=120
WORKER_RESTART_AFTER_JOBS=50
